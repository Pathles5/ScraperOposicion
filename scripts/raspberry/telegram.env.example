# Rellenar con tus credenciales y copiar a /etc/scraper-oposicion/telegram.env
# Bot: @OposicionCamBot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Opcional: modo debug. Si está a `1` o `true`, el bot envía un mensaje a Telegram
# en CADA poll (no solo cuando hay cambios). Útil para verificar que el bot
# está vivo. Por defecto (comentada o unset), solo notifica cuando hay cambios.
# SCRAPER_DEBUG=1
